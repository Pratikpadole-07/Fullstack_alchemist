# --- Server (copy to server/.env) ---
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/company_ownership
JWT_SECRET=change-this-to-a-long-random-string

# Comma-separated not needed; single origin for CORS
CLIENT_ORIGIN=http://localhost:5173

# MOCK=true uses stub MCA/GST data and skips real SMTP (OTP returned in API as devOtp)
# Set to false in production when real APIs and SMTP are configured
MOCK=true

# Skip email transport (same effect as MOCK for OTP delivery — returns devOtp)
SKIP_EMAIL=true

# Nodemailer (when MOCK=false and SKIP_EMAIL=false)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Ownership Verify <noreply@example.com>"

NODE_ENV=development
